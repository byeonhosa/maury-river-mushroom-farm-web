# IP-only DigitalOcean staging example.
# Copy to /opt/mrmf-website-staging/.env.staging on the Droplet and replace all
# "replace-with-..." values there. Do not commit the real .env.staging file.

NODE_ENV=production

# Public staging URL. Do not configure production DNS for Phase 6.
NEXT_PUBLIC_SITE_URL=http://167.99.59.42
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://167.99.59.42
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_REGION_NAME=Maury River Local Development Region
NEXT_PUBLIC_COMMERCE_ADAPTER=medusa-hybrid
NEXT_PUBLIC_CART_ADAPTER=medusa-hybrid
MRMF_ENABLE_DEV_AVAILABILITY_ADMIN=false

# Checkout safety. Live payments stay disabled for IP-only staging.
CHECKOUT_MODE=staging
ENABLE_TEST_PAYMENTS=false
ENABLE_LIVE_PAYMENTS=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=
TAX_MODE=placeholder

# Compose/Postgres. Generate these values on the server.
POSTGRES_DB=mrmf_staging
POSTGRES_USER=mrmf
POSTGRES_PASSWORD=replace-with-server-generated-postgres-password
DATABASE_URL=postgres://mrmf:replace-with-server-generated-postgres-password@postgres:5432/mrmf_staging?sslmode=disable
PGSSLMODE=disable

# Medusa/backend.
MEDUSA_BACKEND_URL=http://backend:9000
MEDUSA_STORE_CORS=http://167.99.59.42
MEDUSA_ADMIN_CORS=http://167.99.59.42
MEDUSA_AUTH_CORS=http://167.99.59.42
JWT_SECRET=replace-with-server-generated-jwt-secret
COOKIE_SECRET=replace-with-server-generated-cookie-secret
MEDUSA_ADMIN_DISABLED=true
MEDUSA_SEED_SALES_CHANNEL_NAME=Maury River Storefront
MEDUSA_SEED_FULFILLMENT_PROVIDER_ID=manual_manual
MRMF_SHIPPING_SMOKE_SHELF_STABLE_HANDLE=mushroom-salt
REDIS_URL=redis://redis:6379

# Email and notifications. Console preview only; no production provider secrets.
EMAIL_PROVIDER=console
EMAIL_FROM=staging@example.invalid
NOTIFICATION_BASE_URL=http://167.99.59.42
NOTIFICATION_RATE_LIMIT_WINDOW_SECONDS=900
NOTIFICATION_RATE_LIMIT_MAX=5
NOTIFICATION_PREVIEW_TARGET_TYPE=
NOTIFICATION_PREVIEW_TARGET_SLUG=
NOTIFICATION_PREVIEW_AVAILABILITY_STATE=
NOTIFICATION_PREVIEW_SEND_CONSOLE=false

# Future storage placeholders.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
