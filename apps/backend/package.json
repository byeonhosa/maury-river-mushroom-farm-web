{
  "name": "@mrmf/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "medusa develop",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "medusa start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src medusa-config.ts --max-warnings=0",
    "test": "vitest run",
    "db:migrate": "medusa db:migrate",
    "db:setup": "medusa db:setup",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:plan": "ts-node ./src/scripts/seed-plan.ts",
    "seed:verify": "ts-node ./src/scripts/verify-seed.ts",
    "shipping:smoke": "ts-node ./src/scripts/store-api-shipping-smoke.ts",
    "notifications:schema": "ts-node ./src/scripts/notification-schema.ts",
    "notifications:preview": "ts-node ./src/scripts/notification-preview.ts"
  },
  "dependencies": {
    "@medusajs/framework": "^2.8.7",
    "@medusajs/medusa": "^2.8.7",
    "@mrmf/shared": "workspace:*",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/node": "^22.14.1",
    "ts-node": "10.9.2",
    "vitest": "^3.1.1"
  }
}
